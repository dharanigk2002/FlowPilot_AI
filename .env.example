POSTGRES_DB=flowpilot
POSTGRES_USER=flowpilot
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

BACKEND_PORT=8080
FRONTEND_PORT=3000
OLLAMA_PORT=11434

NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000

AUTH_COOKIE_NAME=FLOWPILOT_ACCESS_TOKEN
